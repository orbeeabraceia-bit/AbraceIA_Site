generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String?
  source    String   @default("contact")
  consent   Boolean
  createdAt DateTime @default(now())
}

model QuizResult {
  id        String   @id @default(cuid())
  score     Int
  answers   Json
  email     String?
  createdAt DateTime @default(now())
}
