# Site
NEXT_PUBLIC_SITE_URL=https://abraceia.com

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Email (Resend) — notificações de lead
RESEND_API_KEY=
RESEND_FROM_EMAIL=AbraceIA <contato@orbeelabs.com>
LEAD_NOTIFICATION_EMAIL=contato@orbeelabs.com

# IA — Anthropic direto OU Vercel AI Gateway (Cap. 4.1 AbraceIA)
# Defina UMA das chaves. Com AI_GATEWAY_API_KEY, o modelo usa o formato
# "provider/modelo"; com ANTHROPIC_API_KEY, o prefixo "anthropic/" é ignorado.
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=
AI_MODEL=anthropic/claude-sonnet-4-6

# Analytics (ativar somente após consentimento LGPD)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=

# Meta Pixel + Conversions API (gateado por consentimento de MARKETING)
# NEXT_PUBLIC_FB_PIXEL_ID ativa o Pixel no browser; META_CAPI_TOKEN (token de
# acesso da CAPI no Gerenciador de Eventos) ativa o envio server-side com dedup.
NEXT_PUBLIC_FB_PIXEL_ID=
META_CAPI_TOKEN=

# CRM webhook (opcional — HubSpot, RD Station, Zapier)
CRM_WEBHOOK_URL=
